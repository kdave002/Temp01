# DriftShield environment variables
# Copy to .env for local development if desired.

# GitHub repository context used by /pr-preview and config signals
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPO=your-repo-name
GITHUB_BASE_BRANCH=main

# Optional policy toggle: true/false
AUTO_MERGE_LOW_RISK=false

# Optional write-endpoint protection (recommended in non-local environments)
# If set, /pr-create requires this exact key in header X-DriftShield-Key.
# If unset, /pr-create keeps current behavior (no API-key gate).
DRIFTSHIELD_API_KEY=
